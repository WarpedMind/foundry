{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "DOC_FILES_ARR=({{DOC_FILES_QUOTED}}); jq -n --arg content \"$(for f in \"${DOC_FILES_ARR[@]}\"; do [ -f \"$f\" ] && printf '\\n=== %s ===\\n' \"$f\" && cat \"$f\"; done)\" '{hookSpecificOutput: {hookEventName: \"SessionStart\", additionalContext: $content}}'",
            "statusMessage": "Loading {{DOC_FILES_DISPLAY}}..."
          }
        ]
      }
    ]
  }
}
